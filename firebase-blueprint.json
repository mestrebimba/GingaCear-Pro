{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information and role",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff", "judge", "athlete"] },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Category": {
      "title": "Category",
      "description": "Competition category",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "gender": { "type": "string", "enum": ["M", "F", "Mixed"] }
      },
      "required": ["name", "gender"]
    },
    "Athlete": {
      "title": "Athlete",
      "description": "Registered athlete",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "nickname": { "type": "string" },
        "categoryId": { "type": "string" },
        "group": { "type": "string" },
        "professor": { "type": "string" },
        "photoURL": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "rejected"] },
        "registrationDate": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "fullName", "categoryId", "status"]
    },
    "Bracket": {
      "title": "Bracket",
      "description": "Tournament bracket for a category",
      "type": "object",
      "properties": {
        "categoryId": { "type": "string" },
        "status": { "type": "string" },
        "matches": { "type": "array" }
      },
      "required": ["categoryId", "matches"]
    },
    "Score": {
      "title": "Score",
      "description": "Judge score for a match",
      "type": "object",
      "properties": {
        "matchId": { "type": "string" },
        "judgeId": { "type": "string" },
        "judgeName": { "type": "string" },
        "judgeType": { "type": "string", "enum": ["tecnica", "musicalidade", "criatividade"] },
        "gameType": { "type": "string", "enum": ["angola", "regional"] },
        "athleteId": { "type": "string" },
        "points": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["matchId", "judgeId", "athleteId", "points", "gameType"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Event announcement",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" }
      },
      "required": ["title", "content", "date"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Support chat session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "lastMessage": { "type": "string" },
        "timestamp": { "type": "object" },
        "status": { "type": "string", "enum": ["open", "closed"] },
        "unreadCount": { "type": "number" }
      },
      "required": ["userId", "userName", "status"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "object" },
        "isAI": { "type": "boolean" }
      },
      "required": ["chatId", "senderId", "text"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Competition categories"
    },
    "/athletes/{athleteId}": {
      "schema": "Athlete",
      "description": "Registered athletes"
    },
    "/brackets/{bracketId}": {
      "schema": "Bracket",
      "description": "Tournament brackets"
    },
    "/scores/{scoreId}": {
      "schema": "Score",
      "description": "Match scores"
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Event announcements"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Support chats"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat messages"
    },
    "/settings/{settingId}": {
      "schema": "object",
      "description": "Event settings"
    },
    "/live_streams/{streamId}": {
      "schema": "object",
      "description": "Live stream info"
    },
    "/notifications/{notificationId}": {
      "schema": "object",
      "description": "User notifications"
    }
  }
}
